{
  "name": "vcf-viewer",
  "version": "1.3.2",
  "description": "Variant Call Format viewer with colored bases and metadata",
  "extensions": [
    "vcf"
  ],
  "entry": "index.js",
  "data_source": {
    "type": "text",
    "row_count": "grep -cv '^#' '{file}'",
    "metadata": "grep '^#' '{file}'",
    "rows": "grep -v '^#' '{file}' | sed -n '{start},{end}p'",
    "col_headers": ["CHROM", "POS", "ID", "REF", "ALT", "QUAL", "FILTER", "INFO", "FORMAT", "SAMPLES"],
    "meta_parse": "vcf_style",
    "allow_nonzero_exit": false,
    "fallback": [
      {
        "type": "docker",
        "image": "ubuntu:22.04",
        "row_count": "grep -cv '^#' '{file}'",
        "metadata": "grep '^#' '{file}'",
        "rows": "grep -v '^#' '{file}' | sed -n '{start},{end}p'",
        "col_headers": ["CHROM", "POS", "ID", "REF", "ALT", "QUAL", "FILTER", "INFO", "FORMAT", "SAMPLES"],
        "meta_parse": "vcf_style",
        "allow_nonzero_exit": false
      }
    ]
  }
}
